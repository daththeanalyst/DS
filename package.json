{
  "name": "ds-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "Digital Solutions Consultancy — monorepo for company site, client projects, shared UI, chatbot core, research agents, and premium motion pipeline.",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "templates/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
